# Vercel / local — contact API (api/contact.ts) via IONOS SMTP
# Copy to .env for local API testing with `vercel dev`

SMTP_HOST=smtp.ionos.co.uk
SMTP_PORT=465
SMTP_USER=team@velvetlabs.co.uk
SMTP_PASS=
SMTP_SECURE=true

CONTACT_TO_EMAIL=team@velvetlabs.co.uk
CONTACT_FROM_EMAIL=Velvet Labs <team@velvetlabs.co.uk>
